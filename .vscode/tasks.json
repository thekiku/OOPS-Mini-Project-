{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project",
            "type": "shell",
            "command": "javac",
            "args": [
                "-d",
                "out",
                "src/backend/*.java",
                "src/frontend/*.java"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
